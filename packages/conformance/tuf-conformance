#!/usr/bin/env node
const yargs = require('yargs/yargs')
const { hideBin } = require('yargs/helpers')
const fs = require('fs')
const path = require('path')
const { Updater } = require('tuf-js')

yargs(hideBin(process.argv))
  .version(false)

  // init command
  .command('init <trusted-root>', 'initialize the local metadata cache', (yargs) => {
    return yargs.option('metadata-dir')
  }, (argv) => {
    if (!fs.existsSync(argv.metadataDir)) {
      fs.mkdirSync(argv.metadataDir, { recursive: true });
    }

    fs.copyFileSync(argv.trustedRoot, path.join(argv.metadataDir, 'root.json'));
    console.log(Buffer.from(fs.readFileSync(argv.trustedRoot)).toString())
  })

  // refresh command
  .command('refresh', 'update local metadata from the repository', (yargs) => {
    return yargs.option('metadata-dir').option('metadata-url')
  }, async (argv) => {
    const updater = new Updater({
      metadataBaseUrl: argv.metadataUrl,
      metadataDir: argv.metadataDir,
      targetBaseUrl: '',
      targetDir: ''
    })

    return updater.refresh()
  })

  // download command
  .command('download', 'update local metadata from the repository', (yargs) => {
    return yargs
      .option('metadata-dir')
      .option('metadata-url')
      .option('target-name')
      .option('target-base-url')
      .option('target-dir')
  }, async (argv) => {
    if (!fs.existsSync(argv.targetDir)) {
      fs.mkdirSync(argv.targetDir, { recursive: true });
    }

    const updater = new Updater({
      metadataBaseUrl: argv.metadataUrl,
      metadataDir: argv.metadataDir,
      targetBaseUrl: argv.targetBaseUrl,
      targetDir: argv.targetDir
    })

    const targetInfo = await updater.getTargetInfo(argv.targetName)
    if (!targetInfo) {
      throw new Error(`Target ${argv.targetPath} not found`);
    }

    return updater.downloadTarget(targetInfo)
  })
  .parse()
